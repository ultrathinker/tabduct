# Node
node_modules/
npm-debug.log*
*.tgz

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# .NET build output — scoped to the .NET host so it does NOT swallow
# hosts/node/bin/ (which holds the Node host CLI entry point).
hosts/dotnet/**/bin/
hosts/dotnet/**/obj/
*.user

# Tabduct runtime (machine-specific — generated by `register`)
logs/
*.log
hosts/node/node_path.txt
hosts/*/com.tabduct.host.json
hosts/python/run_host.bat
hosts/python/run_host.sh

# Local extension private key (KEEP OUT OF GIT — pairs with the manifest `key`)
extension/key.pem

# Per-tool agent context files (machine-specific, not part of the project)
CLAUDE.md
AGENTS.md
AGENT.md
QWEN.md
GEMINI.md

# Review / orchestration scratch
_kilo_*
_fable_*
_agy_*
_*prompt*.txt
_*status*.txt
_*_out.log

# Editors / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
