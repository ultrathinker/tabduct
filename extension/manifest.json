{
  "manifest_version": 3,
  "name": "Tabduct",
  "version": "0.0.1",
  "description": "A conduit between CLI coding agents (via MCP) and your real browser tabs.",
  "key": "",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tabduct",
    "default_icon": { "16": "icons/16.png", "24": "icons/24.png", "32": "icons/32.png" }
  },
  "commands": {
    "toggle-share-tab": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "Tabduct: share / unshare the current tab"
    }
  },
  "permissions": [
    "nativeMessaging",
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "tabGroups",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/16.png",
    "24": "icons/24.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "64": "icons/64.png",
    "128": "icons/128.png"
  }
}
